/* app.wxss 全局样式 */

/* 基础样式 */
page {
  font-family: 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  background-color: #f5f5f5;
  font-size: 16px;
  line-height: 1.5;
  color: #333333;
}

/* 容器样式 */
.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* 标题样式 - 大字体适合老年人 */
title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

/* 卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
  overflow: hidden;
}

.card:hover {
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
  transform: translateY(-2rpx);
}

/* 按钮样式 */
.btn {
  display: block;
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  transition: all 0.3s ease;
  border: none;
  cursor: pointer;
}

.btn:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.btn-primary {
  background-color: #4CAF50;
  color: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(76, 175, 80, 0.3);
}

.btn-primary:hover {
  background-color: #45a049;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.4);
}

.btn-danger {
  background-color: #f44336;
  color: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(244, 67, 54, 0.3);
}

.btn-danger:hover {
  background-color: #da190b;
  box-shadow: 0 4rpx 12rpx rgba(244, 67, 54, 0.4);
}

.btn-default {
  background-color: #f5f5f5;
  color: #333333;
  border: 2rpx solid #e0e0e0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.btn-default:hover {
  background-color: #e0e0e0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

/* 输入框样式 */
.input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  font-size: 32rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
  transition: all 0.3s ease;
  background-color: #ffffff;
}

.input:focus {
  border-color: #4CAF50;
  box-shadow: 0 0 0 4rpx rgba(76, 175, 80, 0.1);
  outline: none;
}

.input:hover {
  border-color: #4CAF50;
}

/* 列表样式 */
.list {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.list-item {
  padding: 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.list-item:last-child {
  border-bottom: none;
}

/* 图标样式 */
.icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
}

/* 提醒样式 */
.reminder {
  background-color: #FFF3E0;
  border-left: 8rpx solid #FF9800;
  padding: 20rpx;
  margin-bottom: 20rpx;
  border-radius: 0 10rpx 10rpx 0;
}

/* 紧急按钮样式 */
.emergency-btn {
  position: fixed;
  bottom: 80rpx;
  right: 30rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #f44336;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(244, 67, 54, 0.4);
  z-index: 999;
}

/* 适配老年用户的大字体模式 */
.old-mode {
  font-size: 18px;
}

.old-mode title {
  font-size: 36rpx;
}

.old-mode .btn {
  font-size: 36rpx;
  height: 90rpx;
  line-height: 90rpx;
}

.old-mode .input {
  font-size: 36rpx;
  height: 90rpx;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .container {
    padding: 15rpx;
  }
  
  title {
    font-size: 28rpx;
  }
  
  .btn {
    height: 70rpx;
    line-height: 70rpx;
    font-size: 28rpx;
  }
  
  .input {
    height: 70rpx;
    font-size: 28rpx;
  }
}