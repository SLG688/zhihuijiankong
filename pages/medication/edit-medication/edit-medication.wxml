<!-- pages/medication/edit-medication/edit-medication.wxml -->
<view class="container">
  <view class="header">
    <text class="title">编辑用药提醒</text>
  </view>
  
  <view class="form">
    <view class="form-item">
      <text class="form-label">药品名称 *</text>
      <input class="form-input" placeholder="请输入药品名称" value="{{editForm.name}}" bindinput="bindFormInput" data-field="name" />
    </view>
    <view class="form-item">
      <text class="form-label">药品规格 *</text>
      <input class="form-input" placeholder="请输入药品规格" value="{{editForm.specification}}" bindinput="bindFormInput" data-field="specification" />
    </view>
    <view class="form-item">
      <text class="form-label">剂量 *</text>
      <input class="form-input" placeholder="请输入剂量" value="{{editForm.dosage}}" bindinput="bindFormInput" data-field="dosage" />
    </view>
    <view class="form-item">
      <text class="form-label">用法 *</text>
      <input class="form-input" placeholder="请输入用法" value="{{editForm.usage}}" bindinput="bindFormInput" data-field="usage" />
    </view>
    <view class="form-item">
      <text class="form-label">频次 *</text>
      <input class="form-input" placeholder="请输入频次" value="{{editForm.frequency}}" bindinput="bindFormInput" data-field="frequency" />
    </view>
    <view class="form-item">
      <text class="form-label">用药时间 *</text>
      <input class="form-input" placeholder="请输入用药时间" value="{{editForm.time}}" bindinput="bindFormInput" data-field="time" />
    </view>
    <view class="form-item">
      <text class="form-label">用药时长 *</text>
      <input class="form-input" placeholder="请输入用药时长" value="{{editForm.duration}}" bindinput="bindFormInput" data-field="duration" />
    </view>
    <view class="form-item">
      <text class="form-label">注意事项</text>
      <textarea class="form-textarea" placeholder="请输入注意事项" value="{{editForm.notes}}" bindinput="bindFormInput" data-field="notes" />
    </view>
  </view>
  
  <view class="footer">
    <button class="btn btn-default" bindtap="cancel">取消</button>
    <button class="btn btn-primary" bindtap="submitForm">确认</button>
  </view>

  <!-- 紧急求助按钮 -->
  <view class="emergency-button" bindtap="goToEmergency">
    <text class="emergency-icon">🆘</text>
    <text class="emergency-text">紧急求助</text>
  </view>
</view>