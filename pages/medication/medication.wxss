/* pages/medication/medication.wxss */

/* 用药提醒样式 */
.medication-item {
  background-color: #f9f9f9;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 15rpx;
  transition: all 0.3s ease;
  border-left: 4rpx solid #e0e0e0;
}

.medication-item:hover {
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transform: translateY(-2rpx);
}

.medication-item:last-child {
  margin-bottom: 0;
}

.medication-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.medication-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  flex: 1;
}

.medication-time {
  font-size: 26rpx;
  color: #666666;
  background-color: #e3f2fd;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.medication-details {
  margin-bottom: 15rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.medication-dosage {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

.medication-status {
  font-size: 24rpx;
  font-weight: bold;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.medication-status.unfinished {
  color: #FF9800;
  background-color: #FFF3E0;
  border: 1rpx solid #FF9800;
}

.medication-status.finished {
  color: #4CAF50;
  background-color: #E8F5E9;
  border: 1rpx solid #4CAF50;
}

.no-medications {
  text-align: center;
  padding: 30rpx 0;
  color: #999999;
  font-size: 28rpx;
}

/* 用药管理样式 */
.card button {
  margin-bottom: 15rpx;
}

.card button:last-child {
  margin-bottom: 0;
}

/* 用药记录样式 */
.record-item {
  display: flex;
  flex-direction: column;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-date {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 5rpx;
}

.record-medication {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 5rpx;
}

.record-time {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 5rpx;
}

.record-status {
  font-size: 24rpx;
  color: #4CAF50;
}

.no-records {
  text-align: center;
  padding: 30rpx 0;
  color: #999999;
  font-size: 28rpx;
}

/* 用药知识样式 */
.knowledge-item {
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.knowledge-item:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.knowledge-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 15rpx;
  display: block;
}

.knowledge-content {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.5;
  margin-bottom: 10rpx;
  display: block;
  padding-left: 20rpx;
}

/* 小按钮样式 */
.small-btn {
  width: 200rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 24rpx;
  border-radius: 30rpx;
}

/* 对话框样式 */
.dialog-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 9999;
  animation: fadeIn 0.3s ease;
}

.dialog-content {
  background-color: #ffffff;
  border-radius: 16rpx;
  width: 85%;
  max-width: 600rpx;
  animation: slideUp 0.3s ease;
  overflow: hidden;
}

.dialog-header {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.dialog-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  text-align: center;
}

.dialog-body {
  padding: 30rpx;
  max-height: 70vh;
  overflow-y: auto;
}

.dialog-message {
  font-size: 28rpx;
  color: #333333;
  text-align: center;
  line-height: 1.4;
}

.dialog-footer {
  padding: 0 30rpx 30rpx;
  display: flex;
  gap: 20rpx;
}

.dialog-footer button {
  flex: 1;
}

/* 表单样式 */
.form-item {
  margin-bottom: 25rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 10rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  height: 120rpx;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  font-size: 26rpx;
  box-sizing: border-box;
  resize: none;
}

/* 按钮样式 */
.btn {
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 10rpx;
  margin: 0;
}

.btn-primary {
  background-color: #4CAF50;
  color: #ffffff;
  border: none;
}

.btn-default {
  background-color: #f0f0f0;
  color: #333333;
  border: none;
}

.btn-danger {
  background-color: #ff4d4f;
  color: #ffffff;
  border: none;
}

/* 动画 */
@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes slideUp {
  from {
    transform: translateY(50rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}