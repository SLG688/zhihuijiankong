<!-- pages/knowledge/knowledge.wxml -->
<view class="container">
  <!-- 知识分类 -->
  <view class="category-section">
    <view wx:for="{{categories}}" wx:key="index" class="category-item" bindtap="selectCategory" data-index="{{index}}">
      <text class="category-text">{{item}}</text>
    </view>
  </view>
  
  <!-- 知识列表 -->
  <view class="card">
    <text class="section-title">护理知识</text>
    <view wx:for="{{knowledgeList}}" wx:key="index" class="knowledge-item" bindtap="viewKnowledgeDetail" data-index="{{index}}">
      <text class="knowledge-title">{{item.title}}</text>
      <text class="knowledge-summary">{{item.summary}}</text>
      <text class="knowledge-date">{{item.date}}</text>
    </view>
    <view wx:if="knowledgeList.length === 0" class="no-knowledge">
      <text>暂无相关知识</text>
    </view>
  </view>
  
  <!-- 健康资讯 -->
  <view class="card">
    <text class="section-title">健康资讯</text>
    <view wx:for="{{healthNews}}" wx:key="index" class="news-item">
      <text class="news-title">{{item.title}}</text>
      <text class="news-date">{{item.date}}</text>
      <button class="btn btn-primary small-btn" bindtap="viewNewsDetail" data-index="{{index}}">阅读全文</button>
    </view>
  </view>
  
  <!-- 常见问题 -->
  <view class="card">
    <text class="section-title">常见问题</text>
    <view wx:for="{{faqList}}" wx:key="index" class="faq-item">
      <text class="faq-question">{{item.question}}</text>
      <text class="faq-answer">{{item.answer}}</text>
    </view>
  </view>

  <!-- 紧急求助按钮 -->
  <view class="emergency-button" bindtap="goToEmergency">
    <text class="emergency-icon">🆘</text>
    <text class="emergency-text">紧急求助</text>
  </view>
</view>