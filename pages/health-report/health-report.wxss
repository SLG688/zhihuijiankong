/* pages/health-report/health-report.wxss */

/* 报告头部样式 */
.report-header {
  text-align: center;
  margin-bottom: 20rpx;
  padding: 20rpx 0;
  background-color: #4CAF50;
  color: #ffffff;
  border-radius: 16rpx;
}

.report-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  display: block;
}

.report-date {
  font-size: 24rpx;
  opacity: 0.8;
}

/* 分析项目样式 */
.analysis-item {
  margin-bottom: 15rpx;
  display: flex;
  align-items: flex-start;
}

.analysis-label {
  font-size: 28rpx;
  color: #666666;
  width: 150rpx;
  flex-shrink: 0;
}

.analysis-value {
  font-size: 28rpx;
  color: #333333;
  flex: 1;
  line-height: 1.4;
}

/* 状态样式 */
.status-normal {
  color: #4CAF50;
  font-weight: bold;
}

.status-abnormal {
  color: #f44336;
  font-weight: bold;
}

.status-none {
  color: #999999;
}

/* 报告摘要样式 */
.report-summary {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.4;
  padding: 10rpx 0;
}

/* 建议内容样式 */
.advice-content {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
  white-space: pre-wrap;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .report-title {
    font-size: 32rpx;
  }
  
  .analysis-label {
    width: 120rpx;
    font-size: 24rpx;
  }
  
  .analysis-value {
    font-size: 24rpx;
  }
  
  .report-summary {
    font-size: 24rpx;
  }
  
  .advice-content {
    font-size: 24rpx;
  }
}