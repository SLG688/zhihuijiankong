<!-- pages/health-record/health-record.wxml -->
<view class="container">
  <!-- 个人信息卡片 -->
  <view class="card">
    <text class="section-title">个人信息</text>
    <view class="info-item">
      <text class="info-label">姓名：</text>
      <text class="info-value">{{userInfo.name}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">年龄：</text>
      <text class="info-value">{{userInfo.age}}岁</text>
    </view>
    <view class="info-item">
      <text class="info-label">性别：</text>
      <text class="info-value">{{userInfo.gender}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">联系电话：</text>
      <text class="info-value">{{userInfo.phone}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">紧急联系人：</text>
      <text class="info-value">{{userInfo.emergencyContact}}</text>
    </view>
    <button class="btn btn-primary" bindtap="editPersonalInfo">编辑个人信息</button>
  </view>
  
  <!-- 健康状况卡片 -->
  <view class="card">
    <text class="section-title">健康状况</text>
    <view class="health-condition">
      <view class="condition-item">
        <text class="condition-label">既往病史：</text>
        <text class="condition-value">{{healthCondition.pastIllnesses}}</text>
      </view>
      <view class="condition-item">
        <text class="condition-label">过敏史：</text>
        <text class="condition-value">{{healthCondition.allergies}}</text>
      </view>
      <view class="condition-item">
        <text class="condition-label">当前用药：</text>
        <text class="condition-value">{{healthCondition.currentMedications}}</text>
      </view>
    </view>
    <button class="btn btn-primary" bindtap="editHealthCondition">编辑健康状况</button>
  </view>
  
  <!-- 健康数据记录 -->
  <view class="card">
    <text class="section-title">健康数据记录</text>
    <view class="data-record">
      <view class="record-item">
        <text class="record-label">血压记录</text>
        <text class="record-count">{{bloodPressureRecords.length}}条</text>
        <button class="btn btn-primary small-btn" bindtap="viewBloodPressureRecords">查看</button>
      </view>
      <view class="record-item">
        <text class="record-label">血糖记录</text>
        <text class="record-count">{{bloodSugarRecords.length}}条</text>
        <button class="btn btn-primary small-btn" bindtap="viewBloodSugarRecords">查看</button>
      </view>
      <view class="record-item">
        <text class="record-label">心率记录</text>
        <text class="record-count">{{heartRateRecords.length}}条</text>
        <button class="btn btn-primary small-btn" bindtap="viewHeartRateRecords">查看</button>
      </view>
    </view>
  </view>
  
  <!-- 健康报告 -->
  <view class="card">
    <text class="section-title">健康报告</text>
    <view class="report-item">
      <text class="report-date">2024-01-15</text>
      <text class="report-summary">血压正常，心率稳定，建议保持良好作息</text>
      <button class="btn btn-primary small-btn" bindtap="viewReport">查看详情</button>
    </view>
    <button class="btn btn-primary" bindtap="generateReport">生成新报告</button>
  </view>
  
  <!-- 健康目标 -->
  <view class="card">
    <text class="section-title">健康目标</text>
    <view class="goal-item" wx:for="{{healthGoals}}" wx:key="index">
      <text class="goal-title">{{item.title}}</text>
      <text class="goal-target">{{item.target}}</text>
      <text class="goal-progress">{{item.progress}}%</text>
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{item.progress}}%"></view>
      </view>
    </view>
    <button class="btn btn-primary" bindtap="setHealthGoals">设定健康目标</button>
  </view>
  
  <!-- 紧急求助按钮 -->
  <view class="emergency-btn" bindtap="goToEmergency">
    紧急求助
  </view>
</view>