/* pages/health-record/health-record.wxss */

/* 信息项样式 */
.info-item {
  display: flex;
  margin-bottom: 15rpx;
  align-items: center;
}

.info-label {
  font-size: 28rpx;
  color: #666666;
  width: 200rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  flex: 1;
}

/* 健康状况样式 */
.health-condition {
  margin-bottom: 20rpx;
}

.condition-item {
  margin-bottom: 15rpx;
  line-height: 1.4;
}

.condition-label {
  font-size: 28rpx;
  color: #666666;
  display: block;
  margin-bottom: 5rpx;
}

.condition-value {
  font-size: 28rpx;
  color: #333333;
  padding-left: 20rpx;
}

/* 数据记录样式 */
.data-record {
  margin-bottom: 20rpx;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-label {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.record-count {
  font-size: 28rpx;
  color: #666666;
}

.small-btn {
  width: 120rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 24rpx;
  border-radius: 30rpx;
}

/* 健康报告样式 */
.report-item {
  background-color: #f9f9f9;
  padding: 20rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
}

.report-date {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 10rpx;
  display: block;
}

.report-summary {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.4;
  margin-bottom: 15rpx;
  display: block;
}

/* 健康目标样式 */
.goal-item {
  background-color: #f9f9f9;
  padding: 20rpx;
  border-radius: 10rpx;
  margin-bottom: 15rpx;
}

.goal-title {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 10rpx;
  display: block;
}

.goal-target {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 10rpx;
  display: block;
}

.goal-progress {
  font-size: 24rpx;
  color: #4CAF50;
  margin-bottom: 10rpx;
  display: block;
  text-align: right;
}

.progress-bar {
  width: 100%;
  height: 10rpx;
  background-color: #e0e0e0;
  border-radius: 5rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background-color: #4CAF50;
  border-radius: 5rpx;
  transition: width 0.3s ease;
}