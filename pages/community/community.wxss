/* pages/community/community.wxss */

/* 容器样式 */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 调试信息样式 */
.debug-info {
  background-color: #fff3cd;
  border: 1rpx solid #ffeeba;
  border-radius: 8rpx;
  padding: 15rpx;
  margin-bottom: 20rpx;
}

.debug-info text {
  font-size: 24rpx;
  color: #856404;
}

/* 卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 标题样式 */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  display: block;
}

/* 分类部分样式 */
.category-section {
  display: flex;
  overflow-x: auto;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
  white-space: nowrap;
}

.category-item {
  padding: 15rpx 30rpx;
  margin-right: 15rpx;
  background-color: #f0f0f0;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666666;
  cursor: pointer;
  transition: all 0.3s ease;
}

.category-item.active {
  background-color: #4CAF50;
  color: #ffffff;
}

.category-item:last-child {
  margin-right: 0;
}

/* 社区列表样式 */
.community-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  cursor: pointer;
  transition: all 0.3s ease;
}

.community-item:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.community-item:last-child {
  margin-bottom: 0;
}

.community-info {
  flex: 1;
  margin-right: 20rpx;
}

.community-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 10rpx;
  display: block;
}

.community-desc {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 10rpx;
  display: block;
  line-height: 1.4;
}

.community-stats {
  display: flex;
  gap: 20rpx;
}

.stat-item {
  font-size: 24rpx;
  color: #999999;
}

.community-arrow {
  font-size: 32rpx;
  color: #999999;
}

.no-communities {
  text-align: center;
  padding: 30rpx 0;
  color: #999999;
  font-size: 28rpx;
}

/* 热门帖子样式 */
.post-item {
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  cursor: pointer;
  transition: all 0.3s ease;
}

.post-item:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.post-item:last-child {
  margin-bottom: 0;
}

.post-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 10rpx;
  display: block;
  line-height: 1.4;
}

.post-meta {
  display: flex;
  gap: 20rpx;
  font-size: 24rpx;
  color: #999999;
}

.no-posts {
  text-align: center;
  padding: 30rpx 0;
  color: #999999;
  font-size: 28rpx;
}

/* 管理员功能样式 */
.admin-section {
  margin-top: 20rpx;
}

.admin-section button {
  margin-bottom: 15rpx;
}

.admin-section button:last-child {
  margin-bottom: 0;
}

/* 对话框样式 */
.dialog-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 9999;
  animation: fadeIn 0.3s ease;
}

.dialog-content {
  background-color: #ffffff;
  border-radius: 16rpx;
  width: 80%;
  max-width: 600rpx;
  animation: slideUp 0.3s ease;
  overflow: hidden;
}

.dialog-header {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.dialog-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  text-align: center;
}

.dialog-body {
  padding: 30rpx;
}

.dialog-footer {
  padding: 0 30rpx 30rpx;
  display: flex;
  gap: 20rpx;
}

.dialog-footer button {
  flex: 1;
}

/* 表单样式 */
.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 10rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  resize: none;
}

.form-picker {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  background-color: #ffffff;
}

.picker-text {
  color: #333333;
}

/* 按钮样式 */
.btn {
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 10rpx;
  margin: 0;
}

.btn-primary {
  background-color: #4CAF50;
  color: #ffffff;
  border: none;
}

.btn-default {
  background-color: #f0f0f0;
  color: #333333;
  border: none;
}

/* 动画 */
@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes slideUp {
  from {
    transform: translateY(50rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}