<!-- pages/article-detail/article-detail.wxml -->
<view class="container">
  <!-- 文章内容 -->
  <view class="article-card">
    <text class="article-title">{{article.title}}</text>
    <view class="article-meta">
      <text class="article-author">{{article.author}}</text>
      <text class="article-date">{{article.date}}</text>
      <text class="article-views">{{article.views}}浏览</text>
    </view>
    <view class="article-content">
      <text>{{article.content}}</text>
    </view>
    <view class="article-tags">
      <view wx:for="{{article.tags}}" wx:key="index" class="tag">
        <text>{{item}}</text>
      </view>
    </view>
    <view class="article-actions">
      <view class="action-item" bindtap="likeArticle">
        <text class="action-icon">{{isLiked ? '❤️' : '🤍'}}</text>
        <text class="action-text">{{article.likes}}赞</text>
      </view>
      <view class="action-item" bindtap="shareArticle">
        <text class="action-icon">📤</text>
        <text class="action-text">分享</text>
      </view>
      <view class="action-item" bindtap="collectArticle">
        <text class="action-icon">{{isCollected ? '⭐' : '☆'}}</text>
        <text class="action-text">收藏</text>
      </view>
    </view>
  </view>
  
  <!-- 相关推荐 -->
  <view class="card">
    <text class="section-title">相关推荐</text>
    <view wx:for="{{relatedArticles}}" wx:key="index" class="related-article-item" bindtap="viewRelatedArticle" data-index="{{index}}">
      <text class="related-article-title">{{item.title}}</text>
    </view>
  </view>

  <!-- 紧急求助按钮 -->
  <view class="emergency-button" bindtap="goToEmergency">
    <text class="emergency-icon">🆘</text>
    <text class="emergency-text">紧急求助</text>
  </view>
</view>