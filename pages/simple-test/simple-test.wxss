/* pages/simple-test/simple-test.wxss */
.container {
  padding: 40rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 30rpx;
  display: block;
  text-align: center;
}

.item {
  background-color: #ffffff;
  padding: 20rpx;
  margin-bottom: 10rpx;
  border-radius: 8rpx;
}

.item text {
  font-size: 28rpx;
  color: #666666;
}