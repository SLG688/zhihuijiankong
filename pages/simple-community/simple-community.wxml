<!-- pages/simple-community/simple-community.wxml -->
<view class="container">
  <text class="title">社区页面</text>
  
  <view class="section">
    <text class="section-title">分类</text>
    <view wx:for="{{categories}}" wx:key="index" class="category-item">
      <text>{{item}}</text>
    </view>
  </view>
  
  <view class="admin-section">
    <button class="btn btn-primary" bindtap="manageCategories">管理分类</button>
  </view>
  
  <!-- 管理分类对话框 -->
  <view wx:if="showManageDialog" class="dialog-overlay">
    <view class="dialog-content">
      <view class="dialog-header">
        <text class="dialog-title">管理分类</text>
      </view>
      <view class="dialog-body">
        <view class="form-item">
          <text class="form-label">分类名称 *</text>
          <input class="form-input" placeholder="请输入分类名称" value="{{manageForm.categoryName}}" bindinput="bindManageFormInput" maxlength="20" />
        </view>
      </view>
      <view class="dialog-footer">
        <button class="btn btn-default" bindtap="closeManageDialog">取消</button>
        <button class="btn btn-primary" bindtap="submitManageForm">添加</button>
      </view>
    </view>
  </view>
</view>