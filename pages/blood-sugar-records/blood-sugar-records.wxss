/* pages/blood-sugar-records/blood-sugar-records.wxss */

.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 30rpx;
  display: block;
  text-align: center;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-date {
  flex: 1;
}

.date {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  display: block;
  margin-bottom: 5rpx;
}

.time {
  font-size: 24rpx;
  color: #999999;
  display: block;
  margin-bottom: 5rpx;
}

.type {
  font-size: 20rpx;
  color: #4CAF50;
  background-color: #e8f5e8;
  padding: 2rpx 10rpx;
  border-radius: 10rpx;
  display: inline-block;
}

.record-value {
  text-align: right;
}

.value {
  font-size: 32rpx;
  font-weight: bold;
  color: #4CAF50;
  display: block;
}

.unit {
  font-size: 20rpx;
  color: #999999;
  display: block;
  margin-top: 5rpx;
}

.no-records {
  text-align: center;
  padding: 50rpx 0;
  color: #999999;
  font-size: 28rpx;
}