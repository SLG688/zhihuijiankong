<!-- pages/health-articles/health-articles.wxml -->
<view class="container">
  <!-- 文章分类 -->
  <view class="category-section">
    <view wx:for="{{categories}}" wx:key="index" class="category-item" bindtap="selectCategory" data-index="{{index}}">
      <text class="category-text">{{item.name}}</text>
    </view>
  </view>
  
  <!-- 文章列表 -->
  <view class="card">
    <text class="section-title">健康知识文章</text>
    <view wx:for="{{articles}}" wx:key="index" class="article-item" bindtap="viewArticle" data-index="{{index}}">
      <view class="article-info">
        <text class="article-title">{{item.title}}</text>
        <text class="article-summary">{{item.summary}}</text>
        <view class="article-meta">
          <text class="article-author">{{item.author}}</text>
          <text class="article-date">{{item.date}}</text>
          <text class="article-views">{{item.views}}浏览</text>
        </view>
      </view>
      <view class="article-arrow">→</view>
    </view>
    <view wx:if="articles.length === 0" class="no-articles">
      <text>暂无文章</text>
    </view>
  </view>
  
  <!-- 推荐文章 -->
  <view class="card">
    <text class="section-title">推荐文章</text>
    <view wx:for="{{recommendedArticles}}" wx:key="index" class="article-item" bindtap="viewArticle" data-index="{{index + articles.length}}">
      <view class="article-info">
        <text class="article-title">{{item.title}}</text>
        <text class="article-summary">{{item.summary}}</text>
        <view class="article-meta">
          <text class="article-author">{{item.author}}</text>
          <text class="article-date">{{item.date}}</text>
          <text class="article-views">{{item.views}}浏览</text>
        </view>
      </view>
      <view class="article-arrow">→</view>
    </view>
  </view>
  
  <!-- 管理员功能 -->
  <view wx:if="isAdmin" class="admin-section">
    <button class="btn btn-primary" bindtap="addArticle">添加文章</button>
    <button class="btn btn-primary" bindtap="reviewArticles">审核文章</button>
  </view>

  <!-- 紧急求助按钮 -->
  <view class="emergency-button" bindtap="goToEmergency">
    <text class="emergency-icon">🆘</text>
    <text class="emergency-text">紧急求助</text>
  </view>
</view>