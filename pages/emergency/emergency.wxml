<!-- pages/emergency/emergency.wxml -->
<view class="container">
  <!-- 紧急求助按钮 -->
  <view class="emergency-section">
    <view class="emergency-button" bindtap="callEmergency">
      <text class="emergency-icon">SOS</text>
      <text class="emergency-text">紧急求助</text>
    </view>
    <text class="emergency-tip">点击按钮立即联系紧急联系人</text>
  </view>
  
  <!-- 紧急联系人 -->
  <view class="card">
    <text class="section-title">紧急联系人</text>
    <view wx:for="{{emergencyContacts}}" wx:key="index" class="contact-item">
      <view class="contact-info">
        <text class="contact-name">{{item.name}}</text>
        <text class="contact-relation">{{item.relation}}</text>
      </view>
      <text class="contact-phone">{{item.phone}}</text>
      <button class="btn btn-primary small-btn" bindtap="callContact" data-index="{{index}}">拨打电话</button>
    </view>
    <button class="btn btn-primary" bindtap="addContact">添加紧急联系人</button>
  </view>
  
  <!-- 附近医院 -->
  <view class="card">
    <text class="section-title">附近医院</text>
    <view wx:for="{{nearbyHospitals}}" wx:key="index" class="hospital-item">
      <text class="hospital-name">{{item.name}}</text>
      <text class="hospital-address">{{item.address}}</text>
      <text class="hospital-distance">{{item.distance}}</text>
      <button class="btn btn-primary small-btn" bindtap="navigateToHospital" data-index="{{index}}">导航前往</button>
    </view>
  </view>
  
  <!-- 急救常识 -->
  <view class="card">
    <text class="section-title">急救常识</text>
    <view class="knowledge-item">
      <text class="knowledge-title">心肺复苏术</text>
      <text class="knowledge-content">1. 确认现场安全</text>
      <text class="knowledge-content">2. 检查患者意识和呼吸</text>
      <text class="knowledge-content">3. 呼叫急救电话</text>
      <text class="knowledge-content">4. 进行胸外按压和人工呼吸</text>
    </view>
    <view class="knowledge-item">
      <text class="knowledge-title"> choking急救</text>
      <text class="knowledge-content">1. 站在患者背后</text>
      <text class="knowledge-content">2. 双手环抱患者腰部</text>
      <text class="knowledge-content">3. 快速向上向内挤压腹部</text>
      <text class="knowledge-content">4. 重复直到异物排出</text>
    </view>
  </view>
</view>