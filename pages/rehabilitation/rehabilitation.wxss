/* pages/rehabilitation/rehabilitation.wxss */

/* 训练计划样式 */
.plan-item {
  background-color: #f9f9f9;
  padding: 20rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
}

.plan-item:last-child {
  margin-bottom: 0;
}

.plan-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 10rpx;
  display: block;
}

.plan-description {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 15rpx;
  display: block;
}

/* 训练指导样式 */
.guide-item {
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.guide-item:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.guide-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 15rpx;
  display: block;
}

.guide-content {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.5;
  margin-bottom: 10rpx;
  display: block;
  padding-left: 20rpx;
}

/* 训练记录样式 */
.record-item {
  display: flex;
  flex-direction: column;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-date {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 5rpx;
}

.record-time {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 5rpx;
}

.record-content {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 5rpx;
}

.record-duration {
  font-size: 24rpx;
  color: #4CAF50;
}

.no-records {
  text-align: center;
  padding: 30rpx 0;
  color: #999999;
  font-size: 28rpx;
}

/* 视频指导样式 */
.video-item {
  margin-bottom: 20rpx;
}

.video-item:last-child {
  margin-bottom: 0;
}

.video-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 15rpx;
  display: block;
}

.video-placeholder {
  width: 100%;
  height: 200rpx;
  background-color: #f0f0f0;
  border-radius: 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.play-icon {
  font-size: 60rpx;
  color: #999999;
  margin-bottom: 10rpx;
}

.video-desc {
  font-size: 24rpx;
  color: #666666;
}