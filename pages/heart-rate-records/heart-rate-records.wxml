<!-- pages/heart-rate-records/heart-rate-records.wxml -->
<view class="container">
  <text class="page-title">心率记录</text>
  
  <view class="card">
    <view wx:for="{{records}}" wx:key="index" class="record-item">
      <view class="record-date">
        <text class="date">{{item.date}}</text>
        <text class="time">{{item.time}}</text>
      </view>
      <view class="record-value">
        <text class="value">{{item.value}}</text>
        <text class="unit">次/分</text>
      </view>
    </view>
    <view wx:if="records.length === 0" class="no-records">
      <text>暂无心率记录</text>
    </view>
  </view>
</view>