.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-time {
  font-size: 28rpx;
  color: #666;
  width: 160rpx;
}

.record-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  width: 120rpx;
  text-align: center;
}

.record-status {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  width: 160rpx;
  text-align: center;
}

.status-normal {
  background-color: #e6f7ee;
  color: #4CAF50;
}

.status-warning {
  background-color: #fff3cd;
  color: #ff9800;
}

.status-danger {
  background-color: #fde2e2;
  color: #f44336;
}

.no-records {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.header {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  text-align: center;
}

.summary {
  background-color: #e6f7ee;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.summary-item {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
  font-size: 28rpx;
}

.summary-label {
  color: #666;
}

.summary-value {
  font-weight: bold;
  color: #4CAF50;
}
