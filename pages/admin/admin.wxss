/* pages/admin/admin.wxss */

.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 30rpx;
  display: block;
  text-align: center;
}

/* 标签栏样式 */
.tab-bar {
  display: flex;
  background-color: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  overflow: hidden;
}

.tab-item {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666666;
  border-bottom: 4rpx solid transparent;
  transition: all 0.3s ease;
}

.tab-item.active {
  color: #4CAF50;
  border-bottom-color: #4CAF50;
  font-weight: bold;
}

/* 标签内容样式 */
.tab-content {
  min-height: 600rpx;
}

/* 卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  display: block;
}

/* 用户列表样式 */
.user-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.user-item:last-child {
  border-bottom: none;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 5rpx;
  display: block;
}

.user-role {
  font-size: 24rpx;
  color: #999999;
  display: block;
}

/* 社区列表样式 */
.community-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.community-item:last-child {
  border-bottom: none;
}

.community-info {
  flex: 1;
  margin-right: 20rpx;
}

.community-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 10rpx;
  display: block;
}

.community-stats {
  display: flex;
  gap: 20rpx;
}

.stat-item {
  font-size: 24rpx;
  color: #999999;
}

.community-actions {
  display: flex;
  gap: 10rpx;
  flex-direction: column;
}

/* 内容列表样式 */
.content-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.content-item:last-child {
  border-bottom: none;
}

.content-info {
  flex: 1;
  margin-right: 20rpx;
}

.content-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 10rpx;
  display: block;
  line-height: 1.4;
}

.content-meta {
  display: flex;
  gap: 20rpx;
}

.author {
  font-size: 24rpx;
  color: #999999;
}

.status {
  font-size: 24rpx;
  padding: 2rpx 10rpx;
  border-radius: 10rpx;
}

.status-active, .status-approved {
  background-color: #e8f5e8;
  color: #4CAF50;
}

.status-pending {
  background-color: #fff3e0;
  color: #ff9800;
}

/* 分类列表样式 */
.category-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.category-item:last-child {
  border-bottom: none;
}

.category-name {
  font-size: 28rpx;
  color: #333333;
}

/* 按钮样式 */
.btn {
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 10rpx;
  margin: 0;
}

.btn-primary {
  background-color: #4CAF50;
  color: #ffffff;
  border: none;
}

.btn-default {
  background-color: #f0f0f0;
  color: #333333;
  border: none;
}

.btn-danger {
  background-color: #f44336;
  color: #ffffff;
  border: none;
}

.small-btn {
  width: 120rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 24rpx;
  border-radius: 30rpx;
}

/* 对话框样式 */
.dialog-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 9999;
}

.dialog-content {
  background-color: #ffffff;
  border-radius: 16rpx;
  width: 80%;
  max-width: 600rpx;
  overflow: hidden;
}

.dialog-header {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.dialog-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  text-align: center;
}

.dialog-body {
  padding: 30rpx;
}

.dialog-footer {
  padding: 0 30rpx 30rpx;
  display: flex;
  gap: 20rpx;
}

.dialog-footer button {
  flex: 1;
}

/* 表单样式 */
.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 10rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}