/* pages/recommendation/recommendation.wxss */

/* 推荐项样式 */
.recommendation-item {
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
}

.recommendation-item:last-child {
  margin-bottom: 0;
}

.recommendation-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 10rpx;
  display: block;
}

.recommendation-content {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.4;
  display: block;
}

/* 推荐文章样式 */
.article-item {
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  cursor: pointer;
  transition: all 0.3s ease;
}

.article-item:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.article-item:last-child {
  margin-bottom: 0;
}

.article-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 10rpx;
  display: block;
}

.article-summary {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.4;
  display: block;
}

/* 推荐社区样式 */
.community-item {
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  cursor: pointer;
  transition: all 0.3s ease;
}

.community-item:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.community-item:last-child {
  margin-bottom: 0;
}

.community-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 10rpx;
  display: block;
}

.community-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.4;
  display: block;
}

/* 健康目标样式 */
.goal-item {
  margin-bottom: 20rpx;
}

.goal-item:last-child {
  margin-bottom: 0;
}

.goal-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 10rpx;
  display: block;
}

.goal-progress {
  width: 100%;
  height: 20rpx;
  background-color: #f0f0f0;
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.progress-bar {
  height: 100%;
  background-color: #4CAF50;
  border-radius: 10rpx;
  transition: width 0.5s ease;
}

.goal-status {
  font-size: 24rpx;
  color: #666666;
  display: block;
  text-align: right;
}